@{
    ViewData["Title"] = "Slutsida";
}

<h1>Grattis!</h1>
<p>Du rymde på:</p>
<p><strong id="escapeTimeValue">@ViewBag.EscapeTime</strong></p>

<script>
    const el = document.getElementById("escapeTimeValue");
    const rawValue = el.textContent.trim();

    if (rawValue === "unknown" || isNaN(rawValue)) {
        el.textContent = "Unknown";
    } else {
        // Eftersom 't' redan är millisekunder (t.ex. 1781685982676), gör vi bara om strängen till ett tal direkt
        const startMs = parseInt(rawValue, 10);

        // Räkna ut hur många millisekunder som har gått fram tills NU
        const elapsedMs = Date.now() - startMs;

        // Gör om till sekunder (och använd Math.abs ifall klockan skulle diffa med någon millisekund)
        const totalSeconds = Math.floor(Math.abs(elapsedMs) / 1000);

        // Räkna ut minuter och sekunder
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;

        // Skriv ut det snyggt (t.ex. 4:05)
        el.textContent = `${minutes}:${String(seconds).padStart(2, "0")}`;
    }
</script>