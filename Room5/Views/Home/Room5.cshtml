@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Room 5 - Space Invaders</title>

    <style>
            html,
            body {
                margin: 0;
                padding: 0;
                background: #020205;
                overflow: hidden;
                font-family: Arial, sans-serif;
                color: white;
                width: 100%;
                height: 100%;
            }

            /* Centrerar och skalar spelet i en snygg container */
            #game-container {
                position: relative;
                width: 100%;
                max-width: 1000px;
                margin: 0 auto;
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            canvas {
                display: block;
                background: #050505;
                border-bottom: 2px solid #444;
                max-width: 100%;
                height: auto;
                box-sizing: border-box;
            }

            /* Mobilvänlig och responsiv HUD överst */
            #hud {
                width: 100%;
                box-sizing: border-box;
                background: rgba(10, 10, 20, 0.9);
                padding: 10px 15px;
                font-size: 18px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-bottom: 1px solid #222;
            }

            #hud .controls-info {
                font-size: 12px;
                color: #888;
            }

            #overlay {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, .95);
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                z-index: 100;
                padding: 20px;
                text-align: center;
            }

            button {
                padding: 14px 28px;
                font-size: 20px;
                cursor: pointer;
                background: #00ff88;
                color: black;
                border: none;
                font-weight: bold;
                border-radius: 6px;
            }

            h1 {
                margin-bottom: 20px;
            }

            body {
                touch-action: none;
            }

            /* Responsiva justeringar för mobiler */
            @@media (max-width: 900px) {
                #hud .controls-info {
                    display: none;
                    /* Dölj tangentbordsinfo på mobilen */
                }

                #hud {
                    font-size: 15px;
                }
            }
    </style>
</head>

<body>

    <div id="game-container">
        <div id="hud">
            <div class="controls-info">
                <strong>Controls:</strong> A/D = Move | SPACE = Shoot
            </div>
            <div>Time: <span id="timer">05:00</span></div>
            <div>Score: <span id="score">0</span></div>
        </div>

        <canvas id="gameCanvas" width="1000" height="650"></canvas>
    </div>

    <div id="overlay">
        <h1>Room 5 - Space Invaders</h1>
        <p>Destroy all alien ships to escape.</p>

        <div id="mobileInstructions" style="display:none;">
            <h3>Mobilkontroller</h3>
            <p>Dra fingret över skärmen för att styra skeppet. Det skjuter automatiskt.</p>
        </div>

        <button id="startButton">Start Game</button>
    </div>

    <script>
            const START_PAGE_URL = "/Home/Slutsida";

            const canvas = document.getElementById("gameCanvas");
            const ctx = canvas.getContext("2d");

            const timerText = document.getElementById("timer");
            const scoreText = document.getElementById("score");

            let gameRunning = false;
            let gameOverState = false;

            let score = 0;
            let startTimestamp = 0;

            // Sätts till true när spelaren börjar dra fingret på skärmen (auto-skjut på mobil)
            let autoShoot = false;

            const keys = {};

            const player = {
                x: 475,
                y: 590,
                width: 50,
                height: 20,
                speed: 7
            };

            const bullets = [];
            const enemies = [];
            const enemyBullets = [];

            let enemyDirection = 1;
            let lastShot = 0;

            function createWave() {
                enemies.length = 0;
                for (let row = 0; row < 5; row++) {
                    for (let col = 0; col < 10; col++) {
                        enemies.push({
                            x: 80 + col * 80,
                            y: 50 + row * 50,
                            width: 40,
                            height: 25,
                            alive: true
                        });
                    }
                }
            }

            createWave();

            // Tangentbordslyssnare
            document.addEventListener("keydown", e => { keys[e.key] = true; });
            document.addEventListener("keyup", e => { keys[e.key] = false; });

            const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

            if (isTouchDevice) {
                document.getElementById("mobileInstructions").style.display = "block";
            }

            // Dra fingret på skärmen för att styra skeppet (och starta auto-skjut)
            canvas.addEventListener("touchmove", e => {
                autoShoot = true;
                const rect = canvas.getBoundingClientRect();
                const touchX = e.touches[0].clientX - rect.left;
                player.x = (touchX / rect.width) * canvas.width - player.width / 2;
                player.x = Math.max(0, Math.min(canvas.width - player.width, player.x));
                e.preventDefault();
            }, { passive: false });

            // Starta om med R eller genom att klicka på skärmen vid Game Over
            document.addEventListener("keydown", function (e) {
                if (!gameRunning && (e.key === "r" || e.key === "R")) {
                    location.reload();
                }
            });
            document.addEventListener("touchstart", function () {
                if (gameOverState) {
                    location.reload();
                }
            });

            function collide(a, b) {
                return a.x < b.x + b.width &&
                    a.x + a.width > b.x &&
                    a.y < b.y + b.height &&
                    a.y + a.height > b.y;
            }

            function shoot() {
                bullets.push({
                    x: player.x + player.width / 2 - 2,
                    y: player.y,
                    width: 4,
                    height: 10
                });
            }

            document.getElementById("startButton").addEventListener("click", function () {
                let t = new URLSearchParams(window.location.search).get("t");

                if (!t) {
                    t = Date.now().toString();
                    history.replaceState({}, "", window.location.pathname + "?t=" + t);
                }

                // FIX: Hämtar nu tiden stabilt och direkt från den lokala strängen 't'
                startTimestamp = parseInt(t, 10);

                document.getElementById("overlay").style.display = "none";
                gameRunning = true;
                requestAnimationFrame(gameLoop);
            });

            function update() {
                if (keys["ArrowLeft"] || keys["a"] || keys["A"]) {
                    player.x -= player.speed;
                }
                if (keys["ArrowRight"] || keys["d"] || keys["D"]) {
                    player.x += player.speed;
                }

                player.x = Math.max(0, Math.min(canvas.width - player.width, player.x));

                // Skjut med mellanslag, eller automatiskt när spelaren börjat röra skeppet på mobil
                if ((keys[" "] || autoShoot) && Date.now() - lastShot > 250) {
                    shoot();
                    lastShot = Date.now();
                }

                bullets.forEach(b => b.y -= 10);
                let moveDown = false;

                enemies.forEach(enemy => {
                    if (!enemy.alive) return;
                    enemy.x += enemyDirection;
                    if (enemy.x < 0 || enemy.x + enemy.width > canvas.width) {
                        moveDown = true;
                    }
                });

                if (moveDown) {
                    enemyDirection *= -1;
                    enemies.forEach(enemy => { enemy.y += 20; });
                }

                if (Math.random() < 0.025) {
                    const aliveEnemies = enemies.filter(e => e.alive);
                    if (aliveEnemies.length > 0) {
                        const shooter = aliveEnemies[Math.floor(Math.random() * aliveEnemies.length)];
                        enemyBullets.push({
                            x: shooter.x + 18,
                            y: shooter.y + 20,
                            width: 4,
                            height: 10
                        });
                    }
                }

                enemyBullets.forEach(b => b.y += 5);

                bullets.forEach((bullet, index) => {
                    enemies.forEach(enemy => {
                        if (enemy.alive && collide(bullet, enemy)) {
                            enemy.alive = false;
                            bullets.splice(index, 1);
                            score += 10;
                            scoreText.textContent = score;
                        }
                    });
                });

                enemyBullets.forEach(bullet => {
                    if (collide(bullet, player)) { gameOver(); }
                });

                enemies.forEach(enemy => {
                    if (enemy.alive && enemy.y + enemy.height >= player.y) { gameOver(); }
                });

                if (enemies.length > 0 && enemies.every(e => !e.alive)) {
                    victory();
                }

                const elapsed = Math.floor((Date.now() - startTimestamp) / 1000);
                const remaining = 300 - elapsed;
                const mins = Math.max(0, Math.floor(remaining / 60));
                const secs = Math.max(0, remaining % 60);

                timerText.textContent = mins.toString().padStart(2, "0") + ":" + secs.toString().padStart(2, "0");

                if (remaining <= 0) { victory(); }
            }

            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = "lime";
                ctx.fillRect(player.x, player.y, player.width, player.height);
                ctx.fillStyle = "white";
                bullets.forEach(b => { ctx.fillRect(b.x, b.y, b.width, b.height); });
                ctx.fillStyle = "red";
                enemyBullets.forEach(b => { ctx.fillRect(b.x, b.y, b.width, b.height); });
                ctx.fillStyle = "cyan";
                enemies.forEach(enemy => {
                    if (!enemy.alive) return;
                    ctx.fillRect(enemy.x, enemy.y, enemy.width, enemy.height);
                });
            }

            function gameLoop() {
                if (!gameRunning) return;
                update();
                draw();
                requestAnimationFrame(gameLoop);
            }

            // Starta om med R eller genom att klicka på skärmen vid Game Over
            document.addEventListener("keydown", function (e) {
                if (!gameRunning && (e.key === "r" || e.key === "R")) {
                    restartGame();
                }
            });

            document.addEventListener("touchstart", function () {
                if (gameOverState) {
                    restartGame();
                }
            });

            // En gemensam funktion för att starta om och rensa bort gamla parametrar
            function restartGame() {
                window.location.href = window.location.pathname; // Laddar om sidan UTAN "?t=..." i URL:en
            }

            function gameOver() {
                gameRunning = false;
                gameOverState = true;
                const overlay = document.getElementById("overlay");

                // Ändrade onclick från 'location.reload()' till vår nya 'restartGame()'
                overlay.innerHTML = "<h1>Game Over</h1><p>Tryck på skärmen eller R för att starta om</p><button onclick='restartGame()'>Retry</button>";
                overlay.style.display = "flex";
            }

            function victory() {
                gameRunning = false;
                var t = new URLSearchParams(window.location.search).get("t");
                window.location.href = START_PAGE_URL + "?t=" + t;
            }
    </script>
</body>

</html>