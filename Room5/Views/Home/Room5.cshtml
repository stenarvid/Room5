@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Rum 5 - Space Invaders</title>

    <style>
            html,
            body {
                margin: 0;
                padding: 0;
                background: #020205;
                overflow: hidden;
                font-family: Arial, sans-serif;
                color: white;
                width: 100%;
                height: 100%;
            }

            #game-container {
                position: relative;
                width: 100%;
                max-width: 1000px;
                margin: 0 auto;
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            canvas {
                display: block;
                background: #050505;
                border-bottom: 2px solid #444;
                max-width: 100%;
                height: auto;
                box-sizing: border-box;
            }

            #hud {
                width: 100%;
                box-sizing: border-box;
                background: rgba(10, 10, 20, 0.9);
                padding: 10px 15px;
                font-size: 18px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-bottom: 1px solid #222;
            }

            #hud .controls-info {
                font-size: 12px;
                color: #888;
            }

            .mobile-controls {
                display: none;
            }

            #overlay {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, .95);
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                z-index: 100;
                padding: 20px;
                text-align: center;
            }

            button {
                padding: 14px 28px;
                font-size: 20px;
                cursor: pointer;
                background: #00ff88;
                color: black;
                border: none;
                font-weight: bold;
                border-radius: 6px;
            }

            h1 {
                margin-bottom: 20px;
            }

            body {
                touch-action: none;
            }
    </style>
</head>

<body>

    <div id="game-container">
        <div id="hud">
            <div id="controlsInfo" class="controls-info desktop-controls">
                <strong>Kontroller:</strong> A/D = Flytta | SPACE = Skjut
            </div>

            <div id="mobileControlsInfo" class="controls-info mobile-controls">
                <strong>Touch:</strong> Dra fingret för att styra | Automatisk skjutning
            </div>

            <div>Tid: <span id="timer">05:00</span></div>
            <div>Poäng: <span id="score">0</span></div>
        </div>

        <canvas id="gameCanvas" width="1000" height="650"></canvas>
    </div>

    <div id="overlay">
        <h1>Rum 5 - Space Invaders</h1>
        <p>Förstör alla utomjordiska skepp för att fly.</p>

        <div id="mobileInstructions" style="display:none;">
            <h3>Mobilkontroller</h3>
            <p>Dra fingret över skärmen för att styra skeppet. Det skjuter automatiskt.</p>
        </div>

        <button id="startButton">Starta spelet</button>
    </div>

    <script>
            const START_PAGE_URL = "/Home/Slutsida";

            const canvas = document.getElementById("gameCanvas");
            const ctx = canvas.getContext("2d");

            const timerText = document.getElementById("timer");
            const scoreText = document.getElementById("score");

            let gameRunning = false;
            let gameOverState = false;

            let score = 0;
            let startTimestamp = 0;
            let autoShoot = false;

            const keys = {};

            const player = {
                x: 475,
                y: 590,
                width: 50,
                height: 20,
                speed: 700
            };

            const bullets = [];
            const enemies = [];
            const enemyBullets = [];

            const enemySpeed = 40;
            const bulletVelocity = 600;
            const enemyFireRate = 0.5;
            let enemyDirection = 1;
            let lastShot = 0;

            let lastFrameTime = performance.now();

            function resizeCanvas() {
                const width = Math.min(window.innerWidth, 1000);
                canvas.style.width = width + "px";
                canvas.style.height = (width * 650 / 1000) + "px";

                const isMobile = window.innerWidth <= 900;
                document.getElementById("controlsInfo").style.display = isMobile ? "none" : "block";
                document.getElementById("mobileControlsInfo").style.display = isMobile ? "block" : "none";
                document.getElementById("hud").style.fontSize = isMobile ? "15px" : "18px";
            }

            resizeCanvas();
            window.addEventListener("resize", resizeCanvas);

            function gameLoop(currentTime) {
                if (!gameRunning) return;

                const deltaTime = (currentTime - lastFrameTime) / 1000;
                lastFrameTime = currentTime;

                const safeDelta = Math.min(deltaTime, 0.1);

                update(safeDelta);
                draw();

                requestAnimationFrame(gameLoop);
            }

            function createWave() {
                enemies.length = 0;
                for (let row = 0; row < 5; row++) {
                    for (let col = 0; col < 10; col++) {
                        enemies.push({
                            x: 80 + col * 80,
                            y: 50 + row * 50,
                            width: 40,
                            height: 25,
                            alive: true
                        });
                    }
                }
            }

            createWave();

            // FIX: Behåller nuvarande URL-parametrar (inklusive ?t=...) vid omstart
            function restartGame() {
                window.location.href = window.location.pathname + window.location.search;
            }

            document.addEventListener("keydown", e => { keys[e.key] = true; });
            document.addEventListener("keyup", e => { keys[e.key] = false; });

            const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

            if (isTouchDevice) {
                document.getElementById("mobileInstructions").style.display = "block";
            }

            canvas.addEventListener("touchmove", e => {
                if (!gameRunning) return;
                autoShoot = true;
                const rect = canvas.getBoundingClientRect();
                const touchX = e.touches[0].clientX - rect.left;

                player.x = (touchX / rect.width) * canvas.width - player.width / 2;
                player.x = Math.max(0, Math.min(canvas.width - player.width, player.x));
                e.preventDefault();
            }, { passive: false });

            document.addEventListener("keydown", function (e) {
                if (!gameRunning && (e.key === "r" || e.key === "R")) {
                    restartGame();
                }
            });

            document.addEventListener("touchstart", function () {
                if (gameOverState) {
                    restartGame();
                }
            });

            function collide(a, b) {
                return a.x < b.x + b.width &&
                    a.x + a.width > b.x &&
                    a.y < b.y + b.height &&
                    a.y + a.height > b.y;
            }

            function shoot() {
                bullets.push({
                    x: player.x + player.width / 2 - 2,
                    y: player.y,
                    width: 4,
                    height: 10
                });
            }

            document.getElementById("startButton").addEventListener("click", function () {
                let t = new URLSearchParams(window.location.search).get("t");
                let parsedTime = t ? parseInt(t, 10) : 0;

                if (!t || isNaN(parsedTime) || (Date.now() - parsedTime) / 1000 >= 300) {
                    t = Date.now().toString();
                    parsedTime = parseInt(t, 10);
                    history.replaceState({}, "", window.location.pathname + "?t=" + t);
                }

                startTimestamp = parsedTime;
                autoShoot = false;

                document.getElementById("overlay").style.display = "none";
                gameRunning = true;
                lastFrameTime = performance.now();
                requestAnimationFrame(gameLoop);
            });

            function update(deltaTime) {
                if (keys["ArrowLeft"] || keys["a"] || keys["A"]) {
                    player.x -= player.speed * deltaTime;
                }
                if (keys["ArrowRight"] || keys["d"] || keys["D"]) {
                    player.x += player.speed * deltaTime;
                }

                player.x = Math.max(0, Math.min(canvas.width - player.width, player.x));

                if ((keys[" "] || autoShoot) && Date.now() - lastShot > 250) {
                    shoot();
                    lastShot = Date.now();
                }

                for (let i = bullets.length - 1; i >= 0; i--) {
                    bullets[i].y -= bulletVelocity * deltaTime;
                    if (bullets[i].y < 0) {
                        bullets.splice(i, 1);
                    }
                }

                let hitWall = false;
                enemies.forEach(enemy => {
                    if (!enemy.alive) return;
                    enemy.x += enemyDirection * deltaTime * enemySpeed;

                    if (enemy.x <= 0 || enemy.x + enemy.width >= canvas.width) {
                        hitWall = true;
                    }
                });

                if (hitWall) {
                    enemyDirection *= -1;
                    const enemyDropDistance = window.innerWidth <= 900 ? 10 : 20;
                    enemies.forEach(enemy => {
                        if (enemy.alive) {
                            enemy.x += enemyDirection * 2;
                            enemy.y += enemyDropDistance;
                        }
                    });
                }

                if (Math.random() < enemyFireRate * deltaTime) {
                    const aliveEnemies = enemies.filter(e => e.alive);
                    if (aliveEnemies.length > 0) {
                        const shooter = aliveEnemies[Math.floor(Math.random() * aliveEnemies.length)];
                        enemyBullets.push({
                            x: shooter.x + shooter.width / 2 - 2,
                            y: shooter.y + shooter.height,
                            width: 4,
                            height: 10
                        });
                    }
                }

                for (let i = enemyBullets.length - 1; i >= 0; i--) {
                    enemyBullets[i].y += (bulletVelocity * 0.6) * deltaTime;
                    if (enemyBullets[i].y > canvas.height) {
                        enemyBullets.splice(i, 1);
                    }
                }

                for (let i = bullets.length - 1; i >= 0; i--) {
                    for (let j = 0; j < enemies.length; j++) {
                        if (enemies[j].alive && collide(bullets[i], enemies[j])) {
                            enemies[j].alive = false;
                            bullets.splice(i, 1);
                            score += 10;
                            scoreText.textContent = score;
                            break;
                        }
                    }
                }

                enemyBullets.forEach(bullet => {
                    if (collide(bullet, player)) { gameOver(); }
                });

                enemies.forEach(enemy => {
                    if (enemy.alive && enemy.y + enemy.height >= player.y) { gameOver(); }
                });

                if (enemies.length > 0 && enemies.every(e => !e.alive)) {
                    victory();
                }

                const elapsed = Math.floor((Date.now() - startTimestamp) / 1000);
                const remaining = 300 - elapsed;
                const mins = Math.max(0, Math.floor(remaining / 60));
                const secs = Math.max(0, remaining % 60);

                timerText.textContent = mins.toString().padStart(2, "0") + ":" + secs.toString().padStart(2, "0");

                if (remaining <= 0) { victory(); }
            }

            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                ctx.fillStyle = "lime";
                ctx.fillRect(player.x, player.y, player.width, player.height);

                ctx.fillStyle = "white";
                bullets.forEach(b => { ctx.fillRect(b.x, b.y, b.width, b.height); });

                ctx.fillStyle = "red";
                enemyBullets.forEach(b => { ctx.fillRect(b.x, b.y, b.width, b.height); });

                ctx.fillStyle = "cyan";
                enemies.forEach(enemy => {
                    if (!enemy.alive) return;
                    ctx.fillRect(enemy.x, enemy.y, enemy.width, enemy.height);
                });
            }

            function gameOver() {
                gameRunning = false;
                gameOverState = true;
                const overlay = document.getElementById("overlay");
                overlay.innerHTML = "<h1>Spelet är slut</h1><p>Tryck på skärmen eller R för att starta om</p><button onclick='restartGame()'>Försök igen</button>";
                overlay.style.display = "flex";
            }

            function victory() {
                gameRunning = false;
                var t = new URLSearchParams(window.location.search).get("t");
                window.location.href = START_PAGE_URL + "?t=" + t;
            }
    </script>
</body>

</html>